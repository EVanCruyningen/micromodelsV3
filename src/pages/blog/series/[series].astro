---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TagChip from '../../../components/TagChip.astro';
import { readingTime } from '../../../utils/readingTime';

export async function getStaticPaths() {
  const blogEntries = await getCollection('blog');
  const series = [...new Set(blogEntries.map((e) => e.data.series).filter(Boolean))];
  return series.map((s) => ({
    params: { series: s! },
    props: { series: s! },
  }));
}

const { series } = Astro.props;
const allBlog = await getCollection('blog');
const entries = allBlog
  .filter((e) => e.data.series === series)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title={`${series} series`} description={`Blog posts in the ${series} series.`} currentPath="/blog/">
  <h1>Series: {series}</h1>

  {
    entries.map((entry) => (
      <article>
        <a href={`/blog/${entry.id}/`} style="text-decoration: none;">
          <h2 style="margin-bottom: 4px;">{entry.data.title}</h2>
        </a>
        <div class="post-meta">
          {entry.data.date.toISOString().split('T')[0]} &middot; {readingTime(entry.body)}
        </div>
        <div class="chips">
          {entry.data.tags.map((tag) => <TagChip tag={tag} />)}
        </div>
      </article>
    ))
  }
</BaseLayout>

<style>
  article {
    padding: 18px 0;
    border-bottom: 1px solid var(--color-border);
  }

  article:last-of-type {
    border-bottom: 0;
  }

  .post-meta {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--color-muted);
    margin-bottom: 8px;
  }
</style>
