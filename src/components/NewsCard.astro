---
import TagChip from './TagChip.astro';

export interface Props {
  title: string;
  href: string;
  date: string;
  sourceLabel: string;
  sourceUrl: string;
  tags?: string[];
}

const { title, href, date, sourceLabel, sourceUrl, tags = [] } = Astro.props;
---

<article>
  <a href={href} style="text-decoration: none;">
    <h2 style="margin-bottom: 4px;">{title}</h2>
  </a>
  <div class="post-meta">
    {date} &middot; <a href={sourceUrl} target="_blank" rel="noopener noreferrer">{sourceLabel}</a>
  </div>
  {
    tags.length > 0 && (
      <div class="chips">
        {tags.map((tag) => <TagChip tag={tag} />)}
      </div>
    )
  }
</article>

<style>
  article {
    padding: 18px 0;
    border-bottom: 1px solid var(--color-border);
  }

  article:last-of-type {
    border-bottom: 0;
  }

  h2 {
    margin-bottom: 4px;
  }

  .post-meta {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--color-muted);
    margin-bottom: 8px;
  }

  .post-meta a {
    color: var(--color-muted);
  }

  .post-meta a:hover {
    color: var(--color-accent);
  }
</style>
