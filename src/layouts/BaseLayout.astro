---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

export interface Props {
  title: string;
  description?: string;
  currentPath?: string;
  ogType?: string;
  ogImage?: string;
}

const { title, description, currentPath = '', ogType = 'website' } = Astro.props;
const site = 'https://micromodels.com';
const fullTitle = title === 'micromodels' ? title : `${title} · micromodels`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={`${site}${Astro.url.pathname}`} />
    <link rel="alternate" type="application/rss+xml" title="micromodels" href="/rss.xml" />
    <meta property="og:title" content={fullTitle} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={`${site}${Astro.url.pathname}`} />
  </head>
  <body>
    <a class="skip" href="#main">Skip to content</a>
    <Nav currentPath={currentPath} />
    <main id="main">
      <div class="main-inner">
        <slot />
      </div>
    </main>
    <Footer />
  </body>
</html>

<style>
  /* Centered content container — all page content lives inside .main-inner */
  .main-inner {
    max-width: var(--container-content);
    margin: 0 auto;
    padding: 40px 20px 80px;
  }

  @media (max-width: 520px) {
    .main-inner {
      padding: 28px 16px 60px;
    }

    /* Match the small-screen font/size that used to live in global.css */
    :global(body) {
      font-size: 17px;
    }

    :global(h1) {
      font-size: 2rem;
    }
  }
</style>
