---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

export interface Props {
  title: string;
  description?: string;
  currentPath?: string;
  ogType?: string;
  ogImage?: string;
}

const { title, description, currentPath = '', ogType = 'website' } = Astro.props;
const site = 'https://micromodels.com';
const fullTitle = title === 'micromodels' ? title : `${title} · micromodels`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={`${site}${Astro.url.pathname}`} />
    <link rel="alternate" type="application/rss+xml" title="micromodels" href="/rss.xml" />
    <meta property="og:title" content={fullTitle} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={`${site}${Astro.url.pathname}`} />
  </head>
  <body>
    <a class="skip" href="#main">Skip to content</a>
    <Nav currentPath={currentPath} />
    <main id="main">
      <slot />
    </main>
    <Footer />
  </body>
</html>
